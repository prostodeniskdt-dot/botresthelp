BOT_TOKEN=your_bot_token_from_botfather
# Для супергруппы ID вида -100… (как в @GetIDsBot). Можно указать без минуса — в коде будет исправлено.
ADMIN_GROUP_CHAT_ID=-1001234567890
# Каталог для allowed_users.json, sessions.json, shift_reminders.json (на Timeweb — persistent volume). По умолчанию ./data
# DATA_DIR=/mnt/tw/data
# Необязательно: свой путь к recipes.json (по умолчанию data/recipes.json из образа)
# RECIPES_PATH=/app/data/recipes.json

# Темы отчётов (message_thread_id). Переопределите при необходимости.
# THREAD_OPENING=20
# THREAD_CLOSING=22
# THREAD_LINE=63
# THREAD_INVOICES=24
# THREAD_MOVE=26
# THREAD_WRITE_OFF=28
# Отдельная тема для напоминаний GoListBar (по умолчанию как THREAD_LINE — лучше задать свою)
# THREAD_GOLIST=120

# Кто может /staff_add, /staff_remove, /staff_list (user_id через запятую)
# ADMIN_USER_IDS=1221087257

# Техкарты: размер страницы кнопок
# TECH_PAGE_SIZE=8

# Фоновый цикл напоминаний смены, секунд (~1 мин)
# REMINDER_LOOP_INTERVAL_S=55
