BOT_TOKEN=your_bot_token_from_botfather
# Для супергруппы ID вида -100… (как в @GetIDsBot). Можно указать без минуса — в коде будет исправлено.
ADMIN_GROUP_CHAT_ID=-1001234567890
# Каталог для allowed_users.json, sessions.json, shift_reminders.json (на Timeweb — persistent volume). По умолчанию ./data
# DATA_DIR=/mnt/tw/data
# RECIPES_PATH=/app/data/recipes.json

# Режим обновлений: auto (по умолчанию), webhook или polling.
# auto — webhook 2 мин, если POST не приходят → polling (забирает pending из очереди).
# BOT_UPDATE_MODE=auto
# POLLING_TIMEOUT_S=30
# WEBHOOK_DELIVERY_CHECK_S=120
# Публичный HTTPS-адрес приложения без слеша на конце.
WEBHOOK_BASE_URL=https://your-domain.example
# Или полный URL webhook вместо WEBHOOK_BASE_URL:
# WEBHOOK_URL=https://your-domain.example/telegram/webhook
WEBHOOK_PATH=/telegram/webhook
# Секрет: если задан в env, Telegram должен присылать его в заголовке X-Telegram-Bot-Api-Secret-Token.
# Значение в Timeweb должно совпадать с тем, что было при setWebhook.
# WEBHOOK_SECRET_TOKEN=change-me
# Не удалять webhook при рестарте контейнера (рекомендуется false).
# DELETE_WEBHOOK_ON_SHUTDOWN=false
# PORT=8000

# Сеть Telegram API (на Timeweb часто нужно подождать 1–3 мин после старта)
# TELEGRAM_CONNECT_TIMEOUT_S=30
# TELEGRAM_REQUEST_TIMEOUT_S=90
# Если api.telegram.org недоступен с сервера — прокси:
# TELEGRAM_PROXY=socks5://host:1080

# THREAD_OPENING=20
# THREAD_CLOSING=22
# THREAD_LINE=63
# ADMIN_USER_IDS=1221087257
# REMINDER_LOOP_INTERVAL_S=55
